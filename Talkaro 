// ── Room Page ──────────────────────────────────────────────────────────────────
function RoomPage({roomId,navigate}){
  const userId=useMemo(()=>getUserId(),[]);
  const {socket,connected}=useSocket();

  const [localStream,setLocalStream]=useState(null);
  const [micEnabled,setMicEnabled]=useState(true);
  const [audioError,setAudioError]=useState(null);
  const [roomUsers,setRoomUsers]=useState([userId]);
  const [toast,setToast]=useState(null);
  const [copied,setCopied]=useState(false);
  const [joining,setJoining]=useState(true);

  // Password gate
  const [passGate,setPassGate]=useState(()=>!!sessionStorage.getItem(`talkaro_room_pw_${roomId}`) && sessionStorage.getItem(`talkaro_room_verified_${roomId}`)!=="1");
  const [passError,setPassError]=useState("");
  const [passShake,setPassShake]=useState(false);

  // Chat
  const [messages,setMessages]=useState([]);
  const [chatOpen,setChatOpen]=useState(false);
  const [unread,setUnread]=useState(0);

  // Reactions (floating)
  const [floatRx,setFloatRx]=useState([]);

  // Emoji picker
  const [showPicker,setShowPicker]=useState(false);
  const pickerRef=useRef(null);

  // Hand raise — map of userId → boolean
  const [hands,setHands]=useState({});
  const myHand=hands[userId]??false;

  const {peers,cleanup}=useWebRTC({socket,roomId,userId,localStream});

  const allParticipants=useMemo(()=>[...new Set([userId,...peers,...roomUsers])],[userId,peers,roomUsers]);
  const isProtected=!!sessionStorage.getItem(`talkaro_room_pw_${roomId}`);

  // Close picker on outside click
  useEffect(()=>{
    if(!showPicker) return;
    const fn=e=>{ if(pickerRef.current&&!pickerRef.current.contains(e.target)) setShowPicker(false); };
    document.addEventListener("mousedown",fn);
    return()=>document.removeEventListener("mousedown",fn);
  },[showPicker]);

  // Mic
  useEffect(()=>{
    if(passGate) return;
    navigator.mediaDevices?.getUserMedia({audio:true,video:false})
      .then(s=>{setLocalStream(s);setAudioError(null);})
      .catch(e=>setAudioError(e.name==="NotAllowedError"?"Microphone access denied. Allow it in browser settings.":"Could not access microphone."));
    return()=>localStream?.getTracks().forEach(t=>t.stop());
  },[passGate]);

  // Socket events
  useEffect(()=>{
    if(!connected||passGate) return;
    socket.emit("join-room",{roomId,userId});
    setJoining(false);

    socket.on("room-users",({users})=>setRoomUsers(users??[userId]));
    socket.on("user-joined",({userId:uid})=>{ setRoomUsers(p=>p.includes(uid)?p:[...p,uid]); addSystemMsg(`${uid.slice(-8).toUpperCase()} joined`); });
    socket.on("user-left",  ({userId:uid})=>{ setRoomUsers(p=>p.filter(x=>x!==uid)); addSystemMsg(`${uid.slice(-8).toUpperCase()} left`); setHands(h=>{const n={...h};delete n[uid];return n;}); });

    socket.on("chat-message",msg=>{
      setMessages(p=>[...p,msg]);
      if(!chatOpen) setUnread(u=>u+1);
    });
    socket.on("reaction",({from,emoji})=>{
      // Add to chat log
      setMessages(p=>[...p,{id:Date.now()+Math.random(),type:"reaction",from,emoji,ts:Date.now()}]);
      // Float it
      spawnFloat(emoji);
    });
    socket.on("hand-raise",({userId:uid,raised})=>{
      setHands(h=>({...h,[uid]:raised}));
      if(raised&&uid!==userId) setToast({message:`${uid.slice(-8).toUpperCase()} raised their hand ✋`,type:"info"});
    });

    return()=>{
      socket.emit("leave-room",{roomId,userId});
      socket.off("room-users"); socket.off("user-joined"); socket.off("user-left");
      socket.off("chat-message"); socket.off("reaction"); socket.off("hand-raise");
    };
  },[connected,passGate,socket,roomId,userId]);

  useEffect(()=>()=>cleanup(),[cleanup]);

  function addSystemMsg(text){
    setMessages(p=>[...p,{id:Date.now()+Math.random(),type:"system",text,ts:Date.now()}]);
  }

  function spawnFloat(emoji){
    const id=++_rxId;
    const x=20+Math.random()*60;
    setFloatRx(p=>[...p,{id,emoji,x}]);
    setTimeout(()=>setFloatRx(p=>p.filter(r=>r.id!==id)),1700);
  }

  // Password verification
  async function verifyPass(pass){
    const stored=sessionStorage.getItem(`talkaro_room_pw_${roomId}`);
    const h=await hashPass(pass.trim());
    if(h===stored){
      sessionStorage.setItem(`talkaro_room_verified_${roomId}`,"1");
      setPassGate(false); setPassError("");
    } else {
      setPassError("Incorrect password"); setPassShake(true);
      setTimeout(()=>setPassShake(false),400);
    }
  }

  function toggleMic(){
    if(!localStream) return;
    const e=!micEnabled;
    localStream.getAudioTracks().forEach(t=>{t.enabled=e;});
    setMicEnabled(e);
    setToast({message:e?"Microphone unmuted":"Microphone muted",type:"info"});
  }

  function toggleHand(){
    const raised=!myHand;
    setHands(h=>({...h,[userId]:raised}));
    socket.emit("hand-raise",{roomId,userId,raised});
    if(raised) setToast({message:"Hand raised ✋ — others can see you",type:"info"});
  }

  function sendMessage(text){
    const msg={id:Date.now()+Math.random(),type:"chat",from:userId,text,ts:Date.now()};
    socket.emit("chat-message",{roomId,...msg});
  }

  function sendReaction(emoji){
    setShowPicker(false);
    socket.emit("reaction",{roomId,from:userId,emoji});
  }

  function openChat(){ setChatOpen(true); setUnread(0); }

  async function copyLink(){ await copyText(`${location.origin}/#/room/${roomId}`); setCopied(true); setToast({message:"Link copied!",type:"success"}); setTimeout(()=>setCopied(false),2000); }

  function leave(){ localStream?.getTracks().forEach(t=>t.stop()); cleanup(); navigate(""); }

  // Password gate screen
  if(passGate){
    return(
      <PasswordModal
        mode="join"
        onConfirm={verifyPass}
        onCancel={()=>navigate("")}
        error={passError}
        shake={passShake}
      />
    );
  }

  return(
    <div style={{minHeight:"100vh",display:"flex",flexDirection:"column",position:"relative"}}>
      <div className="blob" style={{width:500,height:500,top:"-20%",right:"-15%",background:"var(--accent)"}} />

      {/* Header */}
      <header style={{padding:"14px 20px",borderBottom:"1px solid var(--border)",display:"flex",alignItems:"center",gap:12,background:"rgba(10,10,15,.85)",backdropFilter:"blur(14px)",position:"sticky",top:0,zIndex:10}}>
        <button className="btn btn-ghost" style={{padding:"8px 12px",fontSize:12}} onClick={()=>navigate("")}>
          <Icon d={I.back} size={16} />
        </button>
        <div style={{display:"flex",alignItems:"center",gap:10,flex:1,minWidth:0}}>
          <div style={{background:"rgba(108,99,255,.15)",border:"1px solid rgba(108,99,255,.25)",borderRadius:8,padding:"6px 12px",fontFamily:"var(--mono)",fontWeight:700,fontSize:14,letterSpacing:".1em",display:"flex",alignItems:"center",gap:6,flexShrink:0}}>
            <Icon d={I.hash} size={12} stroke="var(--accent)" />{roomId}
            {isProtected&&<Icon d={I.lock} size={12} stroke="var(--yellow)" />}
          </div>
          <span className="tag tag-green"><span className="dot-live" style={{width:6,height:6}} />LIVE</span>
          {Object.values(hands).some(Boolean)&&<span className="tag tag-yellow">✋ {Object.values(hands).filter(Boolean).length}</span>}
        </div>
        <div style={{display:"flex",alignItems:"center",gap:8}}>
          <span style={{fontSize:12,fontFamily:"var(--mono)",color:"var(--muted)",whiteSpace:"nowrap"}}>{allParticipants.length} in room</span>
          <button className="btn btn-ghost tooltip-wrap" style={{padding:"8px 12px"}} onClick={copyLink}>
            <Icon d={copied?I.check:I.copy} size={15} stroke={copied?"var(--green)":"currentColor"} />
            <span className="tooltip-box">Copy invite link</span>
          </button>
        </div>
      </header>

      {/* Body */}
      <div style={{flex:1,display:"flex",overflow:"hidden"}}>
        <main style={{flex:1,padding:"22px 20px",overflowY:"auto",position:"relative",zIndex:1,minWidth:0}}>

          {audioError&&(
            <div style={{background:"rgba(248,113,113,.1)",border:"1px solid rgba(248,113,113,.25)",borderRadius:12,padding:"14px 18px",marginBottom:20,display:"flex",gap:12,alignItems:"flex-start"}}>
              <Icon d={I.warn} size={18} stroke="var(--red)" />
              <div><div style={{fontWeight:600,fontSize:14,color:"var(--red)"}}>Microphone Error</div><div style={{fontSize:13,color:"var(--muted)",marginTop:3}}>{audioError}</div></div>
            </div>
          )}

          {/* Participants */}
          <div style={{marginBottom:24}}>
            <div style={{display:"flex",alignItems:"center",gap:8,marginBottom:14}}>
              <Icon d={I.users} size={15} stroke="var(--muted)" />
              <span style={{fontSize:12,fontFamily:"var(--mono)",color:"var(--muted)",textTransform:"uppercase",letterSpacing:".06em"}}>Participants</span>
            </div>
            {joining
              ? <div style={{display:"flex",alignItems:"center",gap:10,color:"var(--muted)",fontSize:13,fontFamily:"var(--mono)"}}><span style={{width:16,height:16,border:"2px solid var(--accent)",borderTopColor:"transparent",borderRadius:"50%",display:"inline-block",animation:"spin .7s linear infinite"}} />Joining room…</div>
              : <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(110px,1fr))",gap:12}}>
                  {allParticipants.map(id=><PeerTile key={id} peerId={id} isSelf={id===userId} handRaised={hands[id]??false} />)}
                </div>
            }
          </div>

          {/* Info bar */}
          <div style={{background:"var(--raised)",border:"1px solid var(--border)",borderRadius:12,padding:"12px 16px",display:"flex",alignItems:"center",gap:12}}>
            <Icon d={I.lock} size={15} stroke={isProtected?"var(--yellow)":"var(--accent)"} />
            <div>
              <div style={{fontSize:13,fontWeight:600}}>{isProtected?"Password protected · ":""}End-to-end encrypted</div>
              <div style={{fontSize:12,color:"var(--muted)",fontFamily:"var(--mono)",marginTop:2}}>Audio travels peer-to-peer via WebRTC · nothing recorded</div>
            </div>
          </div>
        </main>

        {/* Chat sidebar */}
        {chatOpen&&(
          <ChatPanel
            messages={messages}
            onSend={sendMessage}
            onReact={sendReaction}
            onClose={()=>setChatOpen(false)}
            userId={userId}
          />
        )}
      </div>

      {/* Controls */}
      <div style={{padding:"14px 20px",borderTop:"1px solid var(--border)",background:"rgba(10,10,15,.92)",backdropFilter:"blur(16px)",display:"flex",alignItems:"center",justifyContent:"center",gap:10,position:"sticky",bottom:0,flexWrap:"wrap"}}>

        {/* Mic */}
        <div className="tooltip-wrap">
          <button className="btn" style={{width:52,height:52,borderRadius:"50%",padding:0,background:micEnabled?"rgba(108,99,255,.15)":"rgba(248,113,113,.15)",border:`1px solid ${micEnabled?"rgba(108,99,255,.35)":"rgba(248,113,113,.35)"}`,boxShadow:micEnabled?"0 0 20px rgba(108,99,255,.2)":"0 0 20px rgba(248,113,113,.2)"}} onClick={toggleMic} disabled={!localStream}>
            <Icon d={micEnabled?I.mic:I.micOff} size={20} stroke={micEnabled?"var(--accent)":"var(--red)"} />
          </button>
          <span className="tooltip-box">{micEnabled?"Mute":"Unmute"}</span>
        </div>

        {/* Waveform */}
        <div style={{padding:"10px 16px",background:"var(--raised)",border:"1px solid var(--border)",borderRadius:999,display:"flex",alignItems:"center",gap:10}}>
          <WaveBars active={micEnabled&&!!localStream} bars={6} />
          <span style={{fontSize:12,fontFamily:"var(--mono)",color:"var(--muted)"}}>{micEnabled?"live":"muted"}</span>
        </div>

        {/* Hand raise */}
        <div className="tooltip-wrap">
          <button className={`btn ${myHand?"btn-yellow":"btn-ghost"}`} style={{width:52,height:52,borderRadius:"50%",padding:0}} onClick={toggleHand}>
            <span style={{fontSize:20,display:"inline-block",animation:myHand?"handBounce .5s ease-in-out infinite":"none"}}>✋</span>
          </button>
          <span className="tooltip-box">{myHand?"Lower hand":"Raise hand"}</span>
        </div>

        {/* Emoji reaction */}
        <div className="tooltip-wrap" ref={pickerRef} style={{position:"relative"}}>
          <button className="btn btn-ghost" style={{width:52,height:52,borderRadius:"50%",padding:0}} onClick={()=>setShowPicker(s=>!s)}>
            <Icon d={I.smile} size={20} />
          </button>
          <span className="tooltip-box">React</span>
          {showPicker&&(
            <div className="emoji-picker" style={{bottom:"calc(100% + 10px)",left:"50%",transform:"translateX(-50%)"}}>
              {["👍","❤️","😂","😮","🔥","🎉","👏","💯","🤔","😢","👎","✨","🙌","😍","🤣","💪","🥳","🫡","⭐","🫶"].map(e=>(
                <button key={e} className="emoji-btn" onClick={()=>sendReaction(e)}>{e}</button>
              ))}
            </div>
          )}
        </div>

        {/* Chat */}
        <div className="tooltip-wrap" style={{position:"relative"}}>
          <button className={`btn ${chatOpen?"btn-active":"btn-ghost"}`} style={{width:52,height:52,borderRadius:"50%",padding:0}} onClick={chatOpen?()=>setChatOpen(false):openChat}>
            <Icon d={I.chat} size={20} stroke={chatOpen?"var(--accent)":"currentColor"} />
          </button>
          <span className="tooltip-box">Chat</span>
          {unread>0&&!chatOpen&&<span className="unread-badge">{unread>9?"9+":unread}</span>}
        </div>

        {/* Leave */}
        <div className="tooltip-wrap">
          <button className="btn" style={{width:52,height:52,borderRadius:"50%",padding:0,background:"rgba(248,113,113,.15)",border:"1px solid rgba(248,113,113,.35)"}} onClick={leave}>
            <Icon d={I.phoneOff} size={20} stroke="var(--red)" />
          </button>
          <span className="tooltip-box">Leave</span>
        </div>
      </div>

      <FloatingReactions reactions={floatRx} />
      {toast&&<Toast message={toast.message} type={toast.type} onClose={()=>setToast(null)} />}
    </div>
  );
}

// ── Router ─────────────────────────────────────────────────────────────────────
export default function Talkaro(){
  const [route,setRoute]=useState(()=>location.hash.replace("#/","")||"");
  useEffect(()=>{
    const fn=()=>setRoute(location.hash.replace("#/","")||"");
    window.addEventListener("hashchange",fn);
    return()=>window.removeEventListener("hashchange",fn);
  },[]);
  function navigate(p){ location.hash=p?`/${p}`:"/"; setRoute(p||""); }
  const m=route.match(/^room\/([A-Z0-9]{3,10})$/i);
  if(m){
    const id=sanitize(m[1]);
    if(!validateRoom(id)) return <RoomPage key={id} roomId={id} navigate={navigate} />;
  }
  return <HomePage navigate={navigate} />;
}
