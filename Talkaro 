// ── Helpers ───────────────────────────────────────────────────────────────────
function genUID() {
  const b = new Uint8Array(12);
  crypto.getRandomValues(b);
  return "u_" + Array.from(b).map(x => x.toString(16).padStart(2,"0")).join("");
}
function getUserId() {
  try {
    let id = sessionStorage.getItem("talkaro_uid");
    if (!id) { id = genUID(); sessionStorage.setItem("talkaro_uid", id); }
    return id;
  } catch { return genUID(); }
}
const ROOM_RE = /^[A-Z0-9]{3,10}$/;
function sanitize(raw) { return String(raw).trim().toUpperCase().replace(/[^A-Z0-9]/g,"").slice(0,10); }
function validateRoom(id) {
  if (!id) return "Room ID is required";
  if (!ROOM_RE.test(id)) return "3–10 letters/numbers only";
  return null;
}
function avatarColor(id) {
  const p=["#6c63ff","#ff6b9d","#4ade80","#facc15","#38bdf8","#fb923c","#a78bfa","#34d399"];
  let h=0; for(const c of id) h=(h*31+c.charCodeAt(0))>>>0;
  return p[h%p.length];
}
function initials(id) { return id.slice(-4,-2).toUpperCase(); }
