// Simple hash for password comparison (demo — use server-side bcrypt in production)
async function hashPass(pass) {
  const enc = new TextEncoder().encode(pass);
  const buf = await crypto.subtle.digest("SHA-256", enc);
  return Array.from(new Uint8Array(buf)).map(b=>b.toString(16).padStart(2,"0")).join("");
}

// ── Mock Socket ───────────────────────────────────────────────────────────────
function makeMockSocket() {
  const h={};
  let _conn=false;
  setTimeout(()=>{ _conn=true; emit("connect"); },600);
  function emit(ev,...args){ (h[ev]||[]).forEach(fn=>fn(...args)); }
  const sock={
    get connected(){ return _conn; },
    on(ev,fn){ (h[ev]=h[ev]||[]).push(fn); return this; },
    once(ev,fn){ const w=(...a)=>{fn(...a);this.off(ev,w)}; return this.on(ev,w); },
    off(ev,fn){ if(!fn) delete h[ev]; else h[ev]=(h[ev]||[]).filter(x=>x!==fn); return this; },
    emit(ev,data){
      if(ev==="random-talk-join"){
        setTimeout(()=>{
          const r=Math.random().toString(36).slice(2,7).toUpperCase();
          emit("random-talk-matched",{roomId:r});
        },2000);
      }
      // Echo chat messages back (demo only — server broadcasts in production)
      if(ev==="chat-message"){ setTimeout(()=>emit("chat-message",data),30); }
      if(ev==="reaction"){     setTimeout(()=>emit("reaction",data),30); }
      if(ev==="hand-raise"){   setTimeout(()=>emit("hand-raise",data),30); }
    },
  };
  return sock;
  function emit(ev,...a){ (h[ev]||[]).forEach(fn=>fn(...a)); }
}
let _sock=null;
function getSocket(){ if(!_sock) _sock=makeMockSocket(); return _sock; }

// ── useSocket ─────────────────────────────────────────────────────────────────
function useSocket(){
  const ref=useRef(getSocket());
  const [connected,setC]=useState(ref.current.connected);
  useEffect(()=>{
    const s=ref.current;
    const on=()=>setC(true), off=()=>setC(false);
    s.on("connect",on); s.on("disconnect",off);
    if(s.connected) setC(true);
    return ()=>{ s.off("connect",on); s.off("disconnect",off); };
  },[]);
  return {socket:ref.current,connected};
}

// ── useWebRTC (hardened) ──────────────────────────────────────────────────────
const ICE={iceServers:[
  {urls:"stun:stun.l.google.com:19302"},
  {urls:"stun:stun1.l.google.com:19302"},
  // Add TURN credentials here for production NAT traversal
]};
function useWebRTC({socket,roomId,userId,localStream}){
  const pcs=useRef(new Map()), pend=useRef(new Map()), lRef=useRef(localStream);
  const [peers,setPeers]=useState([]);
  useEffect(()=>{ lRef.current=localStream; },[localStream]);

  const refresh=useCallback(()=>setPeers([...pcs.current.keys()]),[]);

  const drain=useCallback(async(rid,pc)=>{
    const q=pend.current.get(rid)??[];
    pend.current.delete(rid);
    for(const c of q){ try{ await pc.addIceCandidate(new RTCIceCandidate(c)); }catch{} }
  },[]);

  const addTracks=useCallback((pc,s)=>{
    if(!s) return;
    const have=pc.getSenders().map(x=>x.track);
    s.getTracks().forEach(t=>{ if(!have.includes(t)) pc.addTrack(t,s); });
  },[]);

  const attachAudio=useCallback((rid,s)=>{
    let el=document.getElementById(`ta-${rid}`);
    if(!el){ el=document.createElement("audio"); el.id=`ta-${rid}`; el.autoplay=true; el.style.display="none"; document.body.appendChild(el); }
    el.srcObject=s??null;
  },[]);

  const createPC=useCallback((rid,s)=>{
    if(pcs.current.has(rid)) return pcs.current.get(rid);
    const pc=new RTCPeerConnection(ICE);
    let neg=false;
    pc.onnegotiationneeded=async()=>{
      if(neg||pc.signalingState!=="stable") return; neg=true;
      try{
        await pc.setLocalDescription(await pc.createOffer());
        socket.emit("webrtc-offer",{roomId,from:userId,to:rid,offer:pc.localDescription});
      }catch(e){console.warn("[RTC]neg",e);}finally{neg=false;}
    };
    pc.onicecandidate=({candidate})=>{ if(candidate) socket.emit("webrtc-ice-candidate",{roomId,from:userId,to:rid,candidate}); };
    pc.ontrack=({streams})=>attachAudio(rid,streams[0]);
    pc.onconnectionstatechange=()=>{
      if(["disconnected","failed","closed"].includes(pc.connectionState)){
        pc.close(); pcs.current.delete(rid); pend.current.delete(rid);
        document.getElementById(`ta-${rid}`)?.remove(); refresh();
      }
    };
    addTracks(pc,s??lRef.current);
    pcs.current.set(rid,pc); refresh(); return pc;
  },[socket,roomId,userId,addTracks,attachAudio,refresh]);

  useEffect(()=>{
    const onOffer=async({from,to,offer})=>{
      if(to!==userId) return;
      try{
        const pc=createPC(from);
        if(pc.signalingState==="have-local-offer"){
          if(userId>from){ try{await pc.setLocalDescription({type:"rollback"});}catch{pcs.current.delete(from);createPC(from);return;} }
          else return;
        }
        await pc.setRemoteDescription(new RTCSessionDescription(offer));
        addTracks(pc,lRef.current);
        const ans=await pc.createAnswer();
        await pc.setLocalDescription(ans);
        socket.emit("webrtc-answer",{roomId,from:userId,to:from,answer:ans});
        await drain(from,pc);
      }catch(e){console.warn("[RTC]offer",e);}
    };
    const onAnswer=async({from,to,answer})=>{
      if(to!==userId) return;
      try{
        const pc=pcs.current.get(from);
        if(!pc||pc.signalingState!=="have-local-offer") return;
        await pc.setRemoteDescription(new RTCSessionDescription(answer));
        await drain(from,pc);
      }catch(e){console.warn("[RTC]answer",e);}
    };
    const onIce=async({from,to,candidate})=>{
      if(to!==userId) return;
      try{
        const pc=pcs.current.get(from);
        if(pc?.remoteDescription) await pc.addIceCandidate(new RTCIceCandidate(candidate));
        else{ const q=pend.current.get(from)??[]; q.push(candidate); pend.current.set(from,q); }
      }catch{}
    };
    const onJoin=({userId:r})=>{ if(r!==userId) createPC(r,lRef.current); };
    const onLeft=({userId:r})=>{
      pcs.current.get(r)?.close(); pcs.current.delete(r); pend.current.delete(r);
      document.getElementById(`ta-${r}`)?.remove(); refresh();
    };
    socket.on("webrtc-offer",onOffer); socket.on("webrtc-answer",onAnswer);
    socket.on("webrtc-ice-candidate",onIce); socket.on("user-joined",onJoin); socket.on("user-left",onLeft);
    return ()=>{
      socket.off("webrtc-offer",onOffer); socket.off("webrtc-answer",onAnswer);
      socket.off("webrtc-ice-candidate",onIce); socket.off("user-joined",onJoin); socket.off("user-left",onLeft);
    };
  },[socket,roomId,userId,createPC,addTracks,drain,refresh]);

  const cleanup=useCallback(()=>{
    pcs.current.forEach(p=>p.close()); pcs.current.clear(); pend.current.clear();
    document.querySelectorAll("audio[id^='ta-']").forEach(e=>e.remove()); setPeers([]);
  },[]);

  return {peers,cleanup};
}

